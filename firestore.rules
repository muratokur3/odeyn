rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(debtData) {
      return isAuthenticated() && (request.auth.uid in debtData.participants);
    }

    function isWithinGracePeriod(createdAt) {
      // 1-Hour Rule: 3600 seconds
      return request.time < timestamp.value(createdAt.toMillis() + 3600000);
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      // Users can see their own profile.
      allow get: if isAuthenticated();
      allow list: if isAdmin();

      // Prevent users from setting isAdmin: true on creation
      allow create: if isOwner(userId)
                    && (!request.resource.data.keys().hasAny(['isAdmin']) || request.resource.data.isAdmin == false);

      allow update: if isOwner(userId)
                    // Protect isAdmin field from self-promotion
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']) || isAdmin());

      match /blockedUsers/{blockedUid} {
        allow read, write: if isOwner(userId);
      }

      // Legacy blocked collection
      match /blocked/{targetUid} {
        allow read, write: if isOwner(userId);
      }

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
        
        match /transactions/{txId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      match /notificationReadStatus/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /notifications/{notifId} {
      // Recipient can read, update (mark as read/shown), or delete
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid
                   && request.resource.data.userId == resource.data.userId;
      // Actor can create
      allow create: if isAuthenticated() && request.resource.data.actorId == request.auth.uid;
      // Admin can do anything
      allow read: if isAdmin();
    }
    
    match /debts/{debtId} {
      // Read/Update: Participants or Admins
      allow read: if isParticipant(resource.data) || isAdmin();
      allow update: if isParticipant(resource.data) || isAdmin();

      // Create: One of the participants must be the requester
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;

      // Delete Rules:
      // 1. LEDGER type: Both participants can delete
      // 2. Regular: Only creator can delete
      // BOTH must be within 1-hour grace period
      allow delete: if isAdmin() || (
        isAuthenticated() && (
          (resource.data.type == 'LEDGER' && isParticipant(resource.data)) ||
          (resource.data.createdBy == request.auth.uid)
        ) && isWithinGracePeriod(resource.data.createdAt)
      );

      match /logs/{logId} {
        allow read, create: if isParticipant(get(/databases/$(database)/documents/debts/$(debtId)).data) || isAdmin();
      }
      
      match /transactions/{txId} {
        allow read, create: if isParticipant(get(/databases/$(database)/documents/debts/$(debtId)).data) || isAdmin();
        // Only creator can delete, and within grace period
        allow delete: if isAdmin() || (
          isAuthenticated() && resource.data.createdBy == request.auth.uid
          && isWithinGracePeriod(resource.data.createdAt)
        );
      }
    }

    match /feedbacks/{feedbackId} {
      // Any authenticated user can submit feedback
      allow create: if isAuthenticated();
      // Read/List allowed only for admins
      allow read, list: if isAdmin();
    }

    match /phone_registry/{hashedPhone} {
      // Public lookup for existence check (by hashed phone number)
      allow get: if true;
      // Register mapping to own UID
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
